[Unit]
Description=MeowAI API
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/MeowAI
ExecStart=/var/www/MeowAI/.venv/bin/python -m uvicorn src.api:app --host 127.0.0.1 --port 8010 --reload
Restart=always
RestartSec=3
Environment=PYTHONIOENCODING=utf-8

[Install]
WantedBy=multi-user.target
